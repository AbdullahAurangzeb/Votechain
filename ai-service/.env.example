# Server
APP_NAME=VoteChain AI Service
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS — comma-separated origins allowed to call this service directly in development
CORS_ORIGIN=http://localhost:5000,http://localhost:3000

# File uploads (multipart)
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE_MB=5

# OCR
EASYOCR_LANGUAGES=en
OCR_BLUR_THRESHOLD=100.0
