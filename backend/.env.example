# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=

# JWT (configure before enabling protected routes)
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Password hashing
BCRYPT_SALT_ROUNDS=12

# CORS — comma-separated origins (dev mode allows all localhost origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080

# File uploads (multer)
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE_MB=5

# AI Service
AI_SERVICE_URL=http://localhost:8000
