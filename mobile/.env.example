# VoteChain Mobile — environment variables
# Flutter reads compile-time vars via --dart-define

# Chrome / desktop (default when unset):
# API_BASE_URL=http://localhost:5000

# Android emulator (host loopback alias):
# API_BASE_URL=http://10.0.2.2:5000

# Physical Android device (PC LAN IPv4 — replace with your machine's IP):
# API_BASE_URL=http://192.168.18.75:5000

# Or set host/port separately for Android physical-device default:
# API_LAN_HOST=192.168.18.75
# API_PORT=5000

API_BASE_URL=http://localhost:5000
